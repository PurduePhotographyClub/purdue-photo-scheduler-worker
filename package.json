{
  "name": "purdue-photography-club-scheduler-worker",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "dev": "wrangler dev --test-scheduled --port 8790",
    "typecheck": "tsc --noEmit",
    "doctor": "npx react-doctor@latest --verbose --no-score --yes",
    "verify": "npm run typecheck && npm run build && npm run doctor"
  },
  "reactDoctor": {
    "ignore": {
      "files": ["dist/**", ".wrangler/**"]
    }
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "wrangler": "^4.95.0"
  }
}
